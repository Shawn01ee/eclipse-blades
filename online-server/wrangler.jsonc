{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "eclipse-blades-relay",
  "main": "src/index.js",
  "compatibility_date": "2026-07-19",
  "durable_objects": {
    "bindings": [
      {
        "name": "ROOMS",
        "class_name": "GameRoom"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["GameRoom"]
    }
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 0.05
  }
}
